#include <winver.h>

// Icon path is absolute because this .rc is configured into the CMake build
// dir and rc.exe resolves relative paths from the .rc's location.
IDI_ICON1 ICON "@CMAKE_SOURCE_DIR@/platform/windows/ScrubCut.ico"

VS_VERSION_INFO VERSIONINFO
FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
FILEFLAGS      0
FILEOS         VOS__WINDOWS32
FILETYPE       VFT_APP
FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        // 0409 = U.S. English, 04B0 = Unicode codepage (1200).
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Gabor Szaloki"
            VALUE "FileDescription",  "ScrubCut"
            VALUE "FileVersion",      "@PROJECT_VERSION@"
            VALUE "InternalName",     "ScrubCut"
            VALUE "OriginalFilename", "ScrubCut.exe"
            VALUE "ProductName",      "ScrubCut"
            VALUE "ProductVersion",   "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
