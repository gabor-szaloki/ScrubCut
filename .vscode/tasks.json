{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure Debug",
            "type": "shell",
            "command": "cmake --preset debug",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake Configure Release",
            "type": "shell",
            "command": "cmake --preset release",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "cmake --build --preset debug",
            "group": "build",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "cmake --build --preset release",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Install Release",
            "type": "shell",
            "command": "cmake --build --preset release && powershell -Command \"Start-Process cmake -ArgumentList '--install','build/release' -Verb RunAs -Wait\"",
            "group": "build",
            "problemMatcher": "$msCompile",
            "osx": {
                "command": "cmake --build --preset release && cmake --install build/release --prefix /Applications"
            }
        }
    ]
}
